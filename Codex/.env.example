FLASK_SECRET_KEY=replace-with-random-secret
TMDB_API_KEY=replace-with-your-tmdb-key
IMDB_MIN_VOTES=1000
DATA_DIR=/var/data
USE_DATABASE=1
# For SQLite (default if DATABASE_URL unset): a local lmr.db is used under /app/data.
# For Postgres (recommended on free hosting), set:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
